NODE_ENV=development
PORT=3001

# ── Database (PostgreSQL / PostGIS) ──────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=site_survey
DB_USER=survey_user
DB_PASSWORD=survey_pass_2024
# Set to "true" to enable TLS (required on managed cloud DBs)
DB_SSL=false

# ── CORS ──────────────────────────────────────────────────────
# Production: https://solar-pro.app,https://site-survey-api-bpyz.onrender.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:8081

# ── Authentication ────────────────────────────────────────────
# Secret used to sign JWTs — use a long random string in production
JWT_SECRET=dev_jwt_secret_change_me
# Secret used to verify SolarPro handoff launch tokens
# MUST match SOLARPRO_HANDOFF_SECRET on SolarPro (Vercel) exactly
SOLARPRO_HANDOFF_SECRET=dev_handoff_secret_change_me
# URL of SolarPro webhook receiver (no trailing slash)
# Production: https://solar-pro.app/api/webhooks/survey-complete
SOLARPRO_WEBHOOK_URL=https://solar-pro.app/api/webhooks/survey-complete
# HMAC signing secret for Survey Backend webhooks
# MUST match SURVEY_WEBHOOK_SECRET on SolarPro (Vercel) exactly
SURVEY_WEBHOOK_SECRET=
# Short-lived access token TTL (e.g. "15m", "1h")
JWT_ACCESS_TTL=15m
# Long-lived refresh token TTL in days
REFRESH_TOKEN_TTL_DAYS=7
# SQLite file path for login/user auth storage
SQLITE_AUTH_DB_PATH=./auth.sqlite

# ── Admin account ─────────────────────────────────────────────
# REQUIRED in production. Falls back to "admin123!" in development only.
ADMIN_PASSWORD=
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@site-survey.local
ADMIN_FULL_NAME=Administrator

# ── Sign-in rate limiting ─────────────────────────────────────
SIGNIN_MAX_FAILURES=5
SIGNIN_WINDOW_MINUTES=15
SIGNIN_LOCK_MINUTES=15

# ── Registration / profile rate limiting ─────────────────────
USERS_REGISTER_MAX_REQUESTS=8
USERS_REGISTER_WINDOW_MINUTES=15
USERS_ME_MAX_REQUESTS=120
USERS_ME_WINDOW_MINUTES=1

# ── Password reset ────────────────────────────────────────────
PASSWORD_RESET_TTL_MINUTES=30

# ── File storage ──────────────────────────────────────────────
# "local" writes to uploads/ folder (default, dev only).
# "s3"    streams to AWS S3 — requires the vars below.
STORAGE_BACKEND=local

# Required when STORAGE_BACKEND=s3
AWS_BUCKET_NAME=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional S3 key prefix / folder (default: "uploads/")
AWS_S3_KEY_PREFIX=uploads/

# ── Roboflow ML inference ─────────────────────────────────────
ROBOFLOW_API_KEY=
ROBOFLOW_MODEL_ID=
ROBOFLOW_API_URL=https://detect.roboflow.com

# ── Email (password reset) ────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@site-survey.local

# ── Apple App Site Association (deep links) ───────────────────
IOS_BUNDLE_ID=com.sitesurvey.mobile
APPLE_TEAM_ID=

# ── Observability (metrics, logging, tracing) ────────────────────
# Optional metrics route guard tuning (future use)
METRICS_ENABLED=true

# ── SQL Server replication sink (optional) ──────────────────────────
SQLSERVER_SYNC_ENABLED=false
SQLSERVER_HOST=
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=
SQLSERVER_USER=
SQLSERVER_PASSWORD=
SQLSERVER_ENCRYPT=true
SQLSERVER_TRUST_CERT=true

# ── Webhook receiver staging behavior ───────────────────────────
# When true, inbound /api/webhooks/survey-complete returns 202 after
# successful signature + schema validation instead of 501.
WEBHOOK_PRE_INGEST_ACCEPT_202=false

# ── Handoff + fallback capture ─────────────────────────────
# Shared HS256 secret used to verify handoff tokens.
SOLARPRO_HANDOFF_SECRET=change_me_handoff_secret

# Optional: if partner domain is unavailable, launch this fallback endpoint:
# https://solar-pro.app/new-survey-fallback?token=<jwt>
PARTNER_FALLBACK_BASE_URL=https://solar-pro.app
