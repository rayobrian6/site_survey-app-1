NODE_ENV=production
PORT=3001

# ── Database ──────────────────────────────────────────────────────────────────
# Render Postgres — set DATABASE_URL in Render dashboard (overrides discrete vars)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=site_survey
DB_USER=survey_user
DB_PASSWORD=survey_pass_2024
DB_SSL=true

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://solar-pro.app,https://site-survey-api-bpyz.onrender.com

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=74de2302af346e9121f13534a35a17748ad1bf79fe22fe0facd1b1a94605d657
JWT_EXPIRES_IN=12h
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7
SQLITE_AUTH_DB_PATH=./auth.sqlite

# ── SolarPro integration ──────────────────────────────────────────────────────
# Shared HS256 secret — MUST match SOLARPRO_HANDOFF_SECRET on Vercel exactly
SOLARPRO_HANDOFF_SECRET=34189a35ebc1d74aca53e46e9c91e79be05c9eebf1ff52323b4d5976bf515548
# HMAC secret for outbound webhooks — MUST match SURVEY_WEBHOOK_SECRET on Vercel exactly
SURVEY_WEBHOOK_SECRET=56185fcc8715915913ff605e14e1f3bba05bad1228a830b990819773d5a8d346
# SolarPro webhook receiver
SOLARPRO_WEBHOOK_URL=https://solar-pro.app/api/webhooks/survey-complete

# ── Sign-in lockout ───────────────────────────────────────────────────────────
SIGNIN_MAX_FAILURES=5
SIGNIN_WINDOW_MINUTES=15
SIGNIN_LOCK_MINUTES=15

# ── Rate limiting ─────────────────────────────────────────────────────────────
USERS_REGISTER_MAX_REQUESTS=8
USERS_REGISTER_WINDOW_MINUTES=15
USERS_ME_MAX_REQUESTS=120
USERS_ME_WINDOW_MINUTES=1

# ── Admin account ─────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@site-survey.local
ADMIN_FULL_NAME=Administrator
ADMIN_PASSWORD=

# ── Password reset ────────────────────────────────────────────────────────────
PASSWORD_RESET_TTL_MINUTES=30

# ── File storage ──────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
AWS_BUCKET_NAME=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_KEY_PREFIX=uploads/

# ── Roboflow ML ───────────────────────────────────────────────────────────────
ROBOFLOW_API_KEY=
ROBOFLOW_MODEL_ID=
ROBOFLOW_API_URL=https://detect.roboflow.com

# ── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@site-survey.local

# ── Observability ─────────────────────────────────────────────────────────────
METRICS_ENABLED=true

# ── Webhook staging ───────────────────────────────────────────────────────────
WEBHOOK_PRE_INGEST_ACCEPT_202=false